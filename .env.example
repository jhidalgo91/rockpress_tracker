# =====================================================
# VARIABLES DE ENTORNO — RockPress Tracker
# =====================================================
# Copia este fichero a .env y rellena los valores.
# NUNCA subas el fichero .env a GitHub.
# =====================================================

# --- PROVEEDOR IA (Se requiere al menos uno) ---
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar (ej: gemini-3.5-flash, gpt-4o, claude-3-5-sonnet-20240620)
AI_MODEL=gemini-3.5-flash

# Segundos de espera entre peticiones a la IA (para evitar rate-limits)
API_DELAY_SECONDS=120

# --- EMAIL (Opcional, con Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM=RockPress Tracker <onboarding@resend.dev>
EMAIL_TO=tuemail@gmail.com
SEND_EMAIL=true

# --- CONFIGURACIÓN DE TRACKING ---
# Cuántos días hacia atrás buscar noticias
DATE_WINDOW_DAYS=3

# Número máximo de artículos nuevos a enviar a la IA (-1 para no poner límite)
# Los artículos se seleccionan por prioridad de medio y fecha.
MAX_ARTICLES_TO_ANALYZE=-1
